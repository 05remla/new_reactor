{
    "model_name": "ibm/granite-4-h-tiny",
    "system_prompt_file": "research_agent_Zed.md",
    "provider_url": "http://localhost:8081/v1",
    "inference_params": {
        "temperature": 0.05,
        "top_p": 0.95,
        "min_p": 0.05,
        "top_k": 5,
        "repeat_penalty": 1.12,
        "max_tokens": 0
    },
    "deepagents": {
        "use_project_deepagents": true,
        "enabled_tools": [
            "append_to_note",
            "clear_scratchpad",
            "file_contents_search",
            "get_long_term_memory",
            "interactive_web_search",
            "list_memory_namespaces",
            "list_notes",
            "read_note",
            "scrape_indexed_urls",
            "search_vault",
            "store_long_term_memory",
            "write_note",
            "write_to_scratchpad"
        ],
        "enabled_subagents": [],
        "inject_subagents_to_prompt": false,
        "semantic_agent": "Tron"
    },
    "enable_max_tool_calls": true,
    "max_sequential_tool_calls": 50,
    "description": "Deep research agent, for in-depth discovery"
}