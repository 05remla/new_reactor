{
    "model_name": "ibm/granite-4-h-tiny",
    "system_prompt_file": "tron_mk3.md",
    "provider_url": "http://localhost:8081/v1",
    "inference_params": {
        "temperature": 0.6,
        "top_p": 0.96,
        "min_p": 0.05,
        "top_k": 20,
        "repeat_penalty": 1.13,
        "max_tokens": 0
    },
    "deepagents": {
        "semantic_agent": "Archivist",
        "use_project_deepagents": true,
        "enabled_tools": [
            "append_to_note",
            "clear_scratchpad",
            "list_notes",
            "manage_memory",
            "read_note",
            "search_vault",
            "write_note"
        ],
        "enabled_subagents": [],
        "inject_subagents_to_prompt": false
    },
    "enable_max_tool_calls": true,
    "max_sequential_tool_calls": 50,
    "description": "Memory recording and retreiving agent"
}