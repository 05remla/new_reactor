{
    "model_name": "qwopus3.5-4b-v3-mtp",
    "system_prompt_file": "tron_mk3.md",
    "provider_url": "http://localhost:8081/v1",
    "inference_params": {
        "temperature": 0.05,
        "top_p": 0.95,
        "min_p": 0.05,
        "top_k": 5,
        "repeat_penalty": 1.12,
        "max_tokens": 0
    },
    "enable_max_tool_calls": true,
    "max_sequential_tool_calls": 50,
    "deepagents": {
        "inject_subagents_to_prompt": false,
        "semantic_agent": "Archivist",
        "use_project_deepagents": true,
        "enabled_tools": [
            "append_to_note",
            "clear_scratchpad",
            "file_contents_search",
            "get_long_term_memory",
            "list_memory_namespaces",
            "list_notes",
            "read_note",
            "search_vault",
            "store_long_term_memory",
            "write_note",
            "write_to_scratchpad"
        ],
        "enabled_subagents": []
    },
    "description": "Report/information reviewer and editor"
}