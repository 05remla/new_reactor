{
    "model_name": "qwopus3.5-4b-v3-mtp",
    "description": "Sysiphus deligator",
    "system_prompt_file": "Sisyphus2.md",
    "provider_url": "http://localhost:8081/v1",
    "inference_params": {
        "temperature": 0.6,
        "top_p": 0.96,
        "min_p": 0.05,
        "top_k": 20,
        "repeat_penalty": 1.12,
        "max_tokens": 0
    },
    "enable_max_tool_calls": true,
    "max_sequential_tool_calls": 50,
    "deepagents": {
        "inject_subagents_to_prompt": true,
        "semantic_agent": "Archivist",
        "use_project_deepagents": true,
        "enabled_tools": [
            "query_knowledge_base",
            "clear_scratchpad",
            "file_contents_search",
            "manage_memory",
            "write_to_scratchpad"
        ],
        "enabled_subagents": [
            "Archivist",
            "Researcher"
        ]
    }
}